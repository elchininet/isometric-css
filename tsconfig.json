{
  "compilerOptions": {
    "outDir": "./",
    "module": "esnext",
    "target": "es6",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "declaration": false,
    "noImplicitAny": true,
    "removeComments": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "rootDir": "./src",
    "paths": {
      "@types": ["./src/@types"],
      "@constants": ["./src/constants"],
      "@classes/*": ["./src/classes/*"],
      "@utilities/*": ["./src/utilities/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}